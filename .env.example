# Terminator v3 Configuration
# ============================================================
# SECURITY WARNING: Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# All secrets should be changed from the defaults before use.
# ============================================================

# ------------------------------------------------------------
# Runtime backend/profile for autonomous mode
# ------------------------------------------------------------
TERMINATOR_MODEL=sonnet
TERMINATOR_PRIMARY_BACKEND=claude
TERMINATOR_RUNTIME_PROFILE=scope-first-hybrid
TERMINATOR_CLAUDE_MODEL=sonnet
TERMINATOR_CODEX_MODEL=gpt-5.4
TERMINATOR_CODEX_FAST_MODEL=gpt-5.4-mini

# ------------------------------------------------------------
# PostgreSQL (pgvector) — shared by db, rag-api, litellm
# ------------------------------------------------------------
POSTGRES_DB=shadowhunter
POSTGRES_USER=postgres
# WARNING: Change this before deploying. Default is insecure.
POSTGRES_PASSWORD=shadowhunter

# ------------------------------------------------------------
# Neo4j
# ------------------------------------------------------------
NEO4J_USER=neo4j
# WARNING: Change this before deploying. Default is insecure.
NEO4J_PASSWORD=terminator

# ------------------------------------------------------------
# LiteLLM
# ------------------------------------------------------------
# WARNING: Change this before deploying. Default is insecure.
LITELLM_MASTER_KEY=sk-terminator-local

# ------------------------------------------------------------
# AI Provider API Keys (required for LiteLLM routing)
# ------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# ------------------------------------------------------------
# Telegram notifications (optional)
# ------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
