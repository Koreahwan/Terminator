{
  "mcpServers": {
    "knowledge-fts": {
      "command": "python3",
      "args": ["tools/mcp-servers/knowledge-fts/server.py"],
      "env": {
        "PYTHONPATH": "tools"
      }
    },
    "semgrep-mcp": {
      "command": "python3",
      "args": ["tools/mcp-servers/semgrep-mcp/server.py"]
    },
    "nuclei-mcp": {
      "command": "python3",
      "args": ["tools/mcp-servers/nuclei-mcp/server.py"]
    },
    "codeql-mcp": {
      "command": "python3",
      "args": ["tools/mcp-servers/codeql-mcp/server.py"]
    },
    "graphrag-security": {
      "command": "python3",
      "args": ["tools/mcp-servers/graphrag-mcp/server.py"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    }
  }
}
